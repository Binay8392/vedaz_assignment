# offline, auto, openai, or together
LLM_PROVIDER=offline

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.1-70B-Instruct-Turbo

# Optional second-pass safety judge for checker.py
ENABLE_LLM_JUDGE=false

# auto, true, or false. "auto" falls back to TF-IDF if unavailable.
USE_SENTENCE_TRANSFORMERS=auto
