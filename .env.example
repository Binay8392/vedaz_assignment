# Synthetic generation and optional API evaluation
LLM_PROVIDER=offline
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.1-70B-Instruct-Turbo

# Hugging Face access is only needed for gated or private repositories.
HF_TOKEN=

# Dataset checker options
ENABLE_LLM_JUDGE=false
USE_SENTENCE_TRANSFORMERS=false

# Local vLLM evaluation and serving
VLLM_API_KEY=
VLLM_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
VLLM_ADAPTER_NAME=vedaz
VLLM_ADAPTER_PATH=/models/adapter
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=4096
